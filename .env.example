# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL=" "

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32 (min 32 chars for production)
JWT_SECRET="  "

# ─── AI (Google Gemini) ───────────────────────────────────────────────────────
# Get from: https://ai.google.dev/
# Model: gemini-2.5-flash (default) or gemini-2.0-pro, gemini-1.5-pro, etc.
GEMINI_API_KEY="your-google-gemini-api-key-here"
GEMINI_MODEL="gemini-2.5-flash"

# ─── FILE STORAGE ─────────────────────────────────────────────────────────────
# Local FS for MVP — change to S3/Supabase bucket path later
UPLOAD_DIR="./uploads"

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── FUTURE: Cloud storage (uncomment when switching from local FS) ───────────
# STORAGE_PROVIDER="s3"            # or "supabase"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="eu-west-1"
# AWS_S3_BUCKET="vltp-documents"

# ─── FUTURE: SMS notifications (Twilio) ──────────────────────────────────────
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""

# ─── EMAIL NOTIFICATIONS (SendGrid) ──────────────────────────────────────────
# Get from: https://sendgrid.com/ (free tier: 100 emails/day)
# Leave unset to use console-log stub for development
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@miningco.gh"
