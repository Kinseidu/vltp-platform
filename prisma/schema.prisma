// Verified Local Talent Platform - Prisma Schema
// Production-ready normalized schema for mining/community recruitment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  APPLICANT
  YOUTH_PRESIDENT
  CHIEF_STAFF
  HR_OFFICER
  ADMIN
}

enum VerificationStatus {
  PENDING
  YOUTH_APPROVED
  CHIEF_CONFIRMED
  VERIFIED
  REJECTED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  REJECTED
  INVITED_FOR_INTERVIEW
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
  FILLED
}

enum DocumentType {
  CV_RESUME
  CERTIFICATE
  LICENSE
  SUPPORTING_DOC
  OTHER
}

enum QuestionType {
  TECHNICAL
  EXPERIENTIAL
  SAFETY_COMPLIANCE
  SCENARIO_BASED
}

enum SkillProficiency {
  BEGINNER
  INTERMEDIATE
  PROFICIENT
  EXPERT
}

enum EligibilityStatus {
  ELIGIBLE
  INELIGIBLE_NOT_VERIFIED
  INELIGIBLE_COMMUNITY
  INELIGIBLE_EXPERIENCE
  INELIGIBLE_MISSING_CERTS
}

enum NotificationType {
  MATCH_ALERT
  VERIFICATION_UPDATE
  APPLICATION_STATUS
  INTERVIEW_INVITE
  SYSTEM
}

// ─── CORE USER & ROLE MODELS ─────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String?
  passwordHash String
  role         UserRole @default(APPLICANT)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  applicantProfile   ApplicantProfile?
  youthCommunity     Community?          @relation("YouthPresident")
  verificationDecisions YouthVerification[]
  chiefConfirmations ChiefConfirmation[]  @relation("ConfirmingOfficer")
  postedJobs         Job[]
  auditLogs          AuditLog[]           @relation("Actor")
  notifications      Notification[]

  @@index([email])
  @@index([role])
}

// ─── COMMUNITY ────────────────────────────────────────────────────────────────

model Community {
  id               Int     @id @default(autoincrement())
  name             String  @unique
  region           String
  description      String?
  isActive         Boolean @default(true)
  youthPresidentId String? @unique

  // Relations
  youthPresident      User?                @relation("YouthPresident", fields: [youthPresidentId], references: [id])
  applicantProfiles   ApplicantProfile[]
  eligibleJobs        JobEligibleCommunity[]
  createdAt           DateTime             @default(now())

  @@index([youthPresidentId])
}

// ─── APPLICANT PROFILE ────────────────────────────────────────────────────────

model ApplicantProfile {
  id                 Int                @id @default(autoincrement())
  userId             String             @unique
  fullName           String
  communityId        Int
  verificationStatus VerificationStatus @default(PENDING)
  bio                String?
  dateOfBirth        DateTime?
  gender             String?
  highestEducation   String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relations
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  community           Community           @relation(fields: [communityId], references: [id])
  skills              ApplicantSkill[]
  workExperiences     WorkExperience[]
  verificationRequest VerificationRequest?
  applications        Application[]

  @@index([userId])
  @@index([communityId])
  @@index([verificationStatus])
}

// ─── SKILLS ───────────────────────────────────────────────────────────────────

model Skill {
  id          Int    @id @default(autoincrement())
  name        String @unique
  category    String // e.g. "Mining Operations", "Safety", "Heavy Equipment"
  description String?

  // Relations
  applicantSkills  ApplicantSkill[]
  jobRequirements  JobRequirement[]
}

model ApplicantSkill {
  id           Int              @id @default(autoincrement())
  applicantId  Int
  skillId      Int
  yearsOfExp   Int              @default(0)
  proficiency  SkillProficiency @default(BEGINNER)
  notes        String?

  // Relations
  applicant ApplicantProfile @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  skill     Skill            @relation(fields: [skillId], references: [id])

  @@unique([applicantId, skillId])
  @@index([applicantId])
}

// ─── WORK EXPERIENCE ─────────────────────────────────────────────────────────

model WorkExperience {
  id          Int       @id @default(autoincrement())
  applicantId Int
  jobTitle    String
  employer    String
  industry    String?
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  description String?
  location    String?

  // Relations
  applicant ApplicantProfile @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([applicantId])
}

// ─── VERIFICATION WORKFLOW ────────────────────────────────────────────────────

model VerificationRequest {
  id          Int                @id @default(autoincrement())
  applicantId Int                @unique
  status      VerificationStatus @default(PENDING)
  submittedAt DateTime           @default(now())
  resolvedAt  DateTime?
  notes       String?

  // Relations
  applicant         ApplicantProfile   @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  youthVerification YouthVerification?
  chiefConfirmation ChiefConfirmation?

  @@index([status])
}

model YouthVerification {
  id               Int                @id @default(autoincrement())
  requestId        Int                @unique
  youthPresidentId String
  decision         VerificationStatus // YOUTH_APPROVED or REJECTED
  notes            String?
  decisionAt       DateTime           @default(now())

  // Relations
  request        VerificationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  youthPresident User                @relation(fields: [youthPresidentId], references: [id])

  @@index([youthPresidentId])
}

model ChiefConfirmation {
  id              Int                @id @default(autoincrement())
  requestId       Int                @unique
  confirmingStaffId String
  status          VerificationStatus // CHIEF_CONFIRMED or REJECTED
  chiefName       String             // Name of the chief (for record)
  notes           String?
  confirmedAt     DateTime           @default(now())

  // Relations
  request         VerificationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  confirmingStaff User                @relation("ConfirmingOfficer", fields: [confirmingStaffId], references: [id])

  @@index([confirmingStaffId])
}

// ─── JOBS ─────────────────────────────────────────────────────────────────────

model Job {
  id              Int       @id @default(autoincrement())
  postedById      String
  title           String
  description     String
  scope           String    // Detailed scope of work
  responsibilities String
  minExperience   Int       @default(0) // Minimum years
  status          JobStatus @default(DRAFT)
  applicationDeadline DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  postedBy             User                   @relation(fields: [postedById], references: [id])
  requirements         JobRequirement[]
  eligibleCommunities  JobEligibleCommunity[]
  requiredDocTypes     JobRequiredDocument[]
  applications         Application[]

  @@index([status])
  @@index([postedById])
}

model JobRequirement {
  id          Int     @id @default(autoincrement())
  jobId       Int
  skillId     Int
  isMandatory Boolean @default(true)
  minYears    Int     @default(0)

  // Relations
  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([jobId, skillId])
  @@index([jobId])
}

model JobEligibleCommunity {
  id          Int @id @default(autoincrement())
  jobId       Int
  communityId Int

  // Relations
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id])

  @@unique([jobId, communityId])
}

model JobRequiredDocument {
  id       Int          @id @default(autoincrement())
  jobId    Int
  docType  DocumentType
  label    String       // Human readable e.g. "Valid Blasting Certificate"
  required Boolean      @default(true)

  // Relations
  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// ─── APPLICATIONS ─────────────────────────────────────────────────────────────

model Application {
  id          Int               @id @default(autoincrement())
  jobId       Int
  applicantId Int
  status      ApplicationStatus @default(DRAFT)
  coverNote   String?
  submittedAt DateTime?
  updatedAt   DateTime          @updatedAt
  createdAt   DateTime          @default(now())

  // Relations
  job       Job              @relation(fields: [jobId], references: [id])
  applicant ApplicantProfile @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  documents ApplicationDocument[]
  shortlistResult ShortlistResult?
  interviewPacks  InterviewQuestionPack[]

  @@unique([jobId, applicantId])
  @@index([jobId])
  @@index([applicantId])
  @@index([status])
}

model ApplicationDocument {
  id            Int          @id @default(autoincrement())
  applicationId Int
  docType       DocumentType
  label         String
  fileName      String
  originalName  String
  storagePath   String
  fileSize      Int          // bytes
  mimeType      String
  uploadedAt    DateTime     @default(now())

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

// ─── AI SHORTLISTING ─────────────────────────────────────────────────────────

model ShortlistResult {
  id                Int               @id @default(autoincrement())
  applicationId     Int               @unique
  matchScore        Float             // 0-100
  eligibilityStatus EligibilityStatus
  skillsMatchScore  Float
  experienceScore   Float
  certsScore        Float
  roleRelevanceScore Float
  reasons           Json              // Array of reason strings
  missingRequirements Json            // Array of missing req strings
  evidenceExtracted Json              // Key claims from documents
  hrOverride        Boolean           @default(false)
  hrOverrideNote    String?
  hrOverrideBy      String?
  generatedAt       DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([matchScore])
  @@index([eligibilityStatus])
}

// ─── INTERVIEW QUESTIONS ──────────────────────────────────────────────────────

model InterviewQuestionPack {
  id            Int       @id @default(autoincrement())
  applicationId Int
  generatedAt   DateTime  @default(now())
  exportedAt    DateTime?
  isEdited      Boolean   @default(false)

  // Relations
  application Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  questions   InterviewQuestion[]

  @@index([applicationId])
}

model InterviewQuestion {
  id           Int          @id @default(autoincrement())
  packId       Int
  type         QuestionType
  question     String
  rubric       String?      // Optional scoring rubric
  mappedTo     String?      // Which job req or doc claim this maps to
  displayOrder Int          @default(0)

  // Relations
  pack InterviewQuestionPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([packId])
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model Notification {
  id        Int              @id @default(autoincrement())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  linkUrl   String?          // Optional deep link
  createdAt DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────

model AuditLog {
  id        Int      @id @default(autoincrement())
  actorId   String
  action    String   // e.g. "VERIFICATION_APPROVED", "JOB_POSTED"
  entity    String   // e.g. "VerificationRequest", "Job"
  entityId  String
  before    Json?
  after     Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  // Relations
  actor User @relation("Actor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ─── SYSTEM SETTINGS ──────────────────────────────────────────────────────────

model SystemSetting {
  key       String   @id
  value     String   // Stored as JSON string or plain text
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([key])
}
